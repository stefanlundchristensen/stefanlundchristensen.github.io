---
import Base from '../../layouts/Base.astro';
import { STEFAN } from '../../data/stefan';
import { getCollection } from 'astro:content';

const s = STEFAN;

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Writing" description="Essays on org design, payments, and scaling teams.">
  <div class="posts-page">
    <header class="posts-topbar">
      <a href="/" class="h-display" style="font-size: 17px;">{s.name}</a>
      <a href="/" class="lbl" style="text-decoration: none;">← Home</a>
    </header>

    <div class="posts-content">
      <h1 class="h-display" style="font-size: 42px; line-height: 1.1; margin: 0 0 12px;">Writing</h1>
      <p style="color: var(--ink-70); margin: 0 0 48px; max-width: 540px;">
        Essays on org design, payments infrastructure, and scaling teams.
      </p>

      {posts.map((post, i) => (
        <a href={`/posts/${post.id}/`} class="post-row" style={i > 0 ? 'border-top: 1px solid var(--ink-10);' : ''}>
          <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 24px; margin-bottom: 4px;">
            <div class="h-display" style="font-size: 21px;">{post.data.title}</div>
            <div class="num" style="font-size: 12px; color: var(--ink-50); white-space: nowrap;">
              {post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </div>
          </div>
          {post.data.description && (
            <div style="color: var(--ink-65); font-size: 15px; margin-bottom: 6px;">{post.data.description}</div>
          )}
          {post.data.categories[0] && (
            <span class="lbl" style="color: var(--accent);">{post.data.categories[0]}</span>
          )}
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .posts-page {
    width: 100%;
    min-height: 100vh;
    padding: 64px 64px 96px;
  }

  .posts-topbar {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    max-width: 880px;
    margin: 0 auto 64px;
  }

  .posts-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .post-row {
    display: block;
    padding: 20px 0;
    color: inherit;
    text-decoration: none;
  }

  @media (max-width: 719px) {
    .posts-page {
      padding: 32px 24px 48px;
    }
  }
</style>
