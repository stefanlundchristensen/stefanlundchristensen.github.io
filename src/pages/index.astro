---
import Base from '../layouts/Base.astro';
import RailClient from '../components/RailClient.tsx';
import SectionObserver from '../components/SectionObserver.astro';
import { STEFAN } from '../data/stefan';
import { getCollection } from 'astro:content';
import { readingTime } from '../lib/readingTime';

const s = STEFAN;

const allPosts = await getCollection('posts');
const publishedPosts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = publishedPosts[0];
const restPosts = publishedPosts.slice(1);

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<Base isHome>
  <div class="home-grid" id="home-root">
    <RailClient client:load />

    <main style="max-width: 720px;">
      <p class="h-display" style="font-size: 32px; line-height: 1.18; margin: 0 0 22px;">
        {s.headline}
      </p>
      <p style="margin: 0 0 28px; color: var(--ink-70); max-width: 620px;">
        Fifteen years scaling European fintech. Most of what I do is the work nobody else wants to own — the migrations, the cleanups, the org designs that decide whether a company scales or stalls.
      </p>

      <div class="metric-strip" aria-label="Selected outcomes">
        {s.metrics.map((m) => (
          <div class="metric-cell">
            <div class="metric-value">{m.value}</div>
            <div class="metric-label">{m.label}</div>
          </div>
        ))}
      </div>

      <section id="work" class="fade-section" style="margin-top: 56px;">
        <h2 class="section-head">The path here</h2>
        <p style="margin: 0 0 18px;">
          I joined Pleo in 2019 at around 100 people, looking to get hands-on after five years advising banks at McKinsey. My first job was migrating 20,000 customers to a new payment processor and unlocking a 20-point margin uplift. That turned into building the entire payments platform from scratch. We went from five European markets to fifteen in eleven months.
        </p>
        <p style="margin: 0 0 18px;">
          As the platform matured, the scope grew. I took on data, developer experience, infrastructure, security, eventually leading 100+ people through a period where we tripled engineering throughput without adding headcount. The unlock was removing friction and treating platform teams as product teams with real users and real outcomes.
        </p>
        <p style="margin: 0 0 18px;">
          Today I lead ~70 people across platform engineering, data, AI infrastructure, and regulated entities. The recent win I'm proudest of: a 70% reduction in card scheme costs through direct negotiation in a duopoly market where you have almost no leverage.
        </p>
        <p style="margin: 0 0 24px;">
          Before Pleo: McKinsey, advising Tier 1 European banks on payments and regulatory strategy. Before that: a PhD in physics at the University of Copenhagen, building atomic clocks beyond the quantum limit.
        </p>
        <a class="link" href="/experience/" style="font-size: 14px;">Full experience →</a>
      </section>

      <div class="rule"></div>

      <section id="about" class="fade-section">
        <h2 class="section-head">About</h2>
        <p style="margin: 0 0 18px;">
          {s.longBio[0]}
        </p>
        <p style="margin: 0;">{s.longBio[1]}</p>
      </section>

      <div class="rule"></div>

      <section id="advisory" class="fade-section">
        <h2 class="section-head">Where I'm strongest</h2>
        {s.proposition.map((p, i) => (
          <div style={`padding: 18px 0;${i > 0 ? ' border-top: 1px solid var(--ink-10);' : ''}`}>
            <div class="h-display" style="font-size: 21px; margin-bottom: 6px;">{p.title}</div>
            <div style="color: var(--ink-78);">{p.body}</div>
          </div>
        ))}
      </section>

      <div class="rule"></div>

      <section id="testimonials" class="fade-section">
        {s.testimonials.map((t) => (
          <div class="testimonial">
            <blockquote>"{t.quote}"</blockquote>
            <cite>{t.cite}</cite>
          </div>
        ))}
      </section>

      <div class="rule"></div>

      <section id="writing" class="fade-section">
        <h2 class="section-head">Writing</h2>

        {featured && (
          <a class="featured" href={`/posts/${featured.id}/`}>
            <div style="width: 56px;">
              <div class="lbl" style="color: var(--accent); margin-bottom: 6px;">Latest</div>
              <div class="num h-display" style="font-size: 26px; color: var(--ink-30);">01</div>
            </div>
            <div>
              <div class="h-display" style="font-size: 26px; line-height: 1.18; margin-bottom: 8px;">
                {featured.data.title}
              </div>
              {featured.data.description && (
                <div style="color: var(--ink-70); font-size: 15px; margin-bottom: 10px;">
                  {featured.data.description}
                </div>
              )}
              <div style="display: flex; gap: 14px; font-size: 11.5px;">
                {featured.data.categories?.[0] && (
                  <span class="lbl" style="color: var(--accent);">{featured.data.categories[0]}</span>
                )}
                <span class="lbl">{formatDate(featured.data.date)}</span>
                <span class="lbl">{readingTime(featured.body ?? '')}</span>
              </div>
            </div>
          </a>
        )}

        {restPosts.map((w, i) => (
          <a
            href={`/posts/${w.id}/`}
            style={`display: block; padding: 20px 0; color: inherit;${i > 0 ? ' border-top: 1px solid var(--ink-10);' : ''}`}
          >
            <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 24px; margin-bottom: 4px;">
              <div class="h-display" style="font-size: 21px;">{w.data.title}</div>
              <div class="num" style="font-size: 12px; color: var(--ink-50); white-space: nowrap;">
                {formatDate(w.data.date)}
              </div>
            </div>
            {w.data.description && (
              <div style="color: var(--ink-65); font-size: 15px; margin-bottom: 6px;">
                {w.data.description}
              </div>
            )}
            <div style="display: flex; gap: 14px;">
              {w.data.categories?.[0] && (
                <span class="lbl" style="color: var(--accent);">{w.data.categories[0]}</span>
              )}
              <span class="lbl">{readingTime(w.body ?? '')}</span>
            </div>
          </a>
        ))}
      </section>

      <footer class="site-footer">
        <a class="link" href={`https://${s.contact.linkedin}`} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a class="link" href="/rss.xml">RSS</a>
        <span class="footer-meta">© 2026 {s.name} · {s.contact.location}</span>
      </footer>
    </main>
  </div>
  <SectionObserver />
</Base>

<style>
  .home-grid {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    min-height: 100vh;
    display: grid;
    grid-template-columns: var(--rail-width-open) 1fr;
    column-gap: var(--column-gap-open);
    padding: var(--page-pt) var(--page-pr) var(--page-pb) var(--page-pl);
    transition: var(--rail-transition);
  }

  :global([data-rail='collapsed']) .home-grid {
    grid-template-columns: var(--rail-width-collapsed) 1fr;
    column-gap: var(--column-gap-collapsed);
  }

  @media (max-width: 719px) {
    .home-grid {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
  }
</style>
